# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# PostgreSQL (Neon or any Postgres provider)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Google Gemini
GOOGLE_AI_API_KEY=AIzaSy_your_google_ai_api_key

# Trigger.dev
TRIGGER_SECRET_KEY=tr_dev_your_trigger_secret_key
TRIGGER_PROJECT_ID=proj_your_trigger_project_id

# Transloadit
NEXT_PUBLIC_TRANSLOADIT_KEY=your_transloadit_key
TRANSLOADIT_SECRET=your_transloadit_secret

# LinkedIn (for attribution console.log)
NEXT_PUBLIC_LINKEDIN_URL=https://www.linkedin.com/in/your-profile/

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
